  },
  "slo.availability.99.95": {
    "badge": "⭐ 결제/B2B SaaS 권장",
    "reason": "연 4.4시간 이하 다운. 3개 AZ + Aurora Multi-AZ + Route53 헬스체크로 달성",
  },
  "slo.region.single": {
    "badge": "✨ 국내 서비스 기본",
    "reason": "서울 리전 단일로 충분. Route53 + Multi-AZ로 AZ 장애는 자동 대응",
  },
  "slo.rpo.24h": {
    "badge": "✨ 비핵심 서비스 적정",
    "reason": "일간 스냅샷으로 충분. 비용 최소화. 반기 1회 복구 테스트 권장",
  },
  "slo.rpo.zero": {
    "badge": "⭐ 금융 트랜잭션 필수",
    "reason": "Aurora 4/6 write quorum으로 커밋된 쓰기 보장 + SQS FIFO 정확히 1회 처리. 데이터 손실 0",
  },
  "slo.rto.lt10min": {
    "badge": "⭐ 거래 서비스 권장",
