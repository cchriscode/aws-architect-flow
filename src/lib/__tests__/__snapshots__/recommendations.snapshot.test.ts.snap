  },
  "data.db_ha.multi_az_read": {
    "badge": "⭐ 고가용성/이커머스 필수",
    "reason": "자동 페일오버 + 읽기 전담 서버. 읽기가 전체 쿼리 70%+ 서비스에서 성능 2배",
  },
  "data.primary_db.aurora_pg": {
    "badge": "⭐ SaaS/B2B 표준",
    "reason": "PostgreSQL Row-Level Security로 테넌트 데이터 격리. JSON 지원으로 유연한 스키마",
  },
  "data.primary_db.documentdb": {
    "badge": "✨ MongoDB 마이그레이션",
    "reason": "기존 MongoDB 코드를 변경 없이 AWS 관리형으로 전환. MongoDB 5.0 호환",
  },
  "data.primary_db.neptune": {
    "badge": "✨ 관계 중심 데이터",
    "reason": "소셜 네트워크, 사기 탐지, 추천 엔진. 데이터 간 관계 탐색에 최적화",
  },
  "data.primary_db.rds_mysql": {
    "badge": "⚠️ 고가용성 시 Aurora 권장",
