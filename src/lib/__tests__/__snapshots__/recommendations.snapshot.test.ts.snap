  },
  "network.hybrid.no": {
    "badge": "✨ Public cloud only",
    "reason": "No on-premises connection needed. Maintain simple architecture without VPN setup",
  },
  "network.nat_strategy.shared": {
    "badge": "✨ Cost savings option",
    "reason": "Save $43+/month sharing 1 NAT GW. Single AZ failure affects all outbound traffic",
  },
  "network.subnet_tier.2tier": {
    "badge": "⭐ Standard for most services",
    "reason": "Public (ALB) + Private (app+DB): Security Groups allow DB access only from app servers",
  },
  "platform.autoscaling_strategy.hpa_only": {
    "badge": "⭐ Default for most EKS services",
    "reason": "CPU-based HPA min:2 max:10: Simplest and most stable K8s scaling method",
  },
  "platform.cluster_strategy.single_ns": {
    "badge": "✨ Suitable for small/single team",
    "reason": "Start with single namespace. Apply separation strategy as teams and services grow",
  },
  "platform.gitops.argocd": {
    "badge": "⭐ EKS GitOps standard",
    "reason": "Git as the source of truth. Deploy history, drift detection, visual UI. De facto standard for EKS GitOps",
  },
  "platform.ingress.alb_controller": {
    "badge": "⭐ AWS-native standard",
    "reason": "Auto ALB creation + WAF/Shield integration. Most natural choice in AWS environments",
  },
  "platform.k8s_backup.git_only": {
    "badge": "✨ Sufficient for small scale",
    "reason": "Velero unnecessary if redeployable via IaC + GitOps. Use DB backups for important data",
  },
  "platform.k8s_monitoring.cloudwatch": {
    "badge": "✨ Recommended for AWS all-in/small scale",
