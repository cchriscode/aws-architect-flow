  "integration.api_type.alb": {
    "badge": "⭐ Default for most services",
    "reason": "ALB alone is sufficient. API Gateway adds unnecessary cost and complexity",
  },
  "integration.api_type.api_gateway": {
    "badge": "✨ Recommended for serverless/IoT",
    "reason": "Direct Lambda integration + Rate Limiting + API key management. Also useful for IoT device authentication",
  },
  "integration.auth.cognito": {
    "badge": "⭐ Standard for B2C services",
    "reason": "10K MAU free (new pool basis). Social login and MFA with config only, no code. Drastically reduces security incidents vs self-implementation",
  },
  "integration.batch_workflow.ecs_scheduled": {
    "badge": "✨ Post-event batch",
    "reason": "Run settlement and statistics aggregation as ECS Tasks after events. Reuse ECS cluster",
  },
  "integration.queue_type.sqs": {
    "badge": "⭐ Standard for order/payment processing",
    "reason": "SQS FIFO: Guaranteed order sequence + exactly-once processing. AWS e-commerce reference standard",
  },
  "integration.sync_async.async": {
    "badge": "⭐ Required for transactional/event services",
    "reason": "Order-payment-inventory-shipping chain: Fault isolation via async separation. AWS standard for payment services",
  },
  "network.account_structure.single": {
    "badge": "✨ Ideal for small scale",
    "reason": "Start with single account + per-environment namespaces. Migrate to multi-account as team grows",
  },
  "network.az_count.1az": {
    "badge": "✨ MVP cost savings",
    "reason": "Minimize cost with 1 NAT GW. Plan immediate upgrade to 2 AZs when transitioning to production",
  },
  "network.az_count.2az": {
    "badge": "⭐ Production service standard",
