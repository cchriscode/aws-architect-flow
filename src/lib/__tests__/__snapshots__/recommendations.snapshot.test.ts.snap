  },
  "scale.data_volume.gb": {
    "badge": "✨ 일반 서비스 적정",
    "reason": "RDS/Aurora 단일 인스턴스로 수년간 충분합니다. 인덱스 설계가 성능 핵심",
  },
  "scale.data_volume.none": {
    "badge": "✨ 연산 위주 서비스",
    "reason": "Lambda + 외부 API 호출 위주. 자체 저장소 최소화로 비용 절감",
  },
  "scale.data_volume.tb": {
    "badge": "✨ 운영 서비스 적정",
    "reason": "S3 Intelligent-Tiering으로 오래된 데이터를 자동으로 저렴하게 보관하세요",
  },
  "scale.dau.medium": {
    "badge": "✨ 성장기 서비스 적정",
    "reason": "DAU 1~10만: Redis 캐시 도입이 필수가 되는 시점입니다",
  },
  "scale.dau.small": {
    "badge": "✨ 초기 이커머스 적정",
    "reason": "스타트업 이커머스 초기 규모. ECS + Aurora로 시작해 트래픽에 맞게 확장하세요",
  },
  "scale.dau.tiny": {
    "badge": "✨ MVP/사내 도구 적정",
    "reason": "검증 단계에는 초소형부터 시작해 트래픽에 맞게 확장하는 것이 비용 효율적입니다",
  },
  "scale.peak_rps.high": {
    "badge": "✨ 캐시 필수 시점",
