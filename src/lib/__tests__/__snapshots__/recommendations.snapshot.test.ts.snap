  },
  "compliance.network_iso.strict": {
    "badge": "⭐ 개인정보 서비스 필수",
    "reason": "앱+DB 프라이빗 서브넷 완전 격리. 인터넷에서 DB 직접 접근 불가",
  },
  "compute.arch_pattern.container": {
    "badge": "⭐ 대부분 서비스 표준",
    "reason": "Docker 컨테이너로 환경 일관성. ECS Fargate로 서버 관리 제로. AWS 권장 기본",
  },
  "compute.compute_node.mixed": {
    "badge": "✨ 비용·안정성 균형",
    "reason": "기본 태스크는 EC2, 스케일아웃은 Fargate. ECS Capacity Provider로 자동 분배",
  },
  "compute.orchestration.eks": {
    "badge": "✨ 대규모 정밀 제어",
    "reason": "Karpenter + KEDA + Argo CD: 수백 개 서비스를 하나의 플랫폼으로 통합 관리",
  },
  "compute.scaling.ecs_asg": {
    "badge": "⭐ 대부분 서비스 기본",
