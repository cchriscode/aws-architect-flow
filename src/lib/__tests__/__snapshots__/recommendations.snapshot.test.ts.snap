  },
  "team.cloud_exp.beginner": {
    "badge": "✨ 관리형 서비스 집중",
    "reason": "ECS Fargate + Aurora Serverless: AWS가 서버·DB를 관리. 코드에만 집중하세요",
  },
  "team.cloud_exp.mid": {
    "badge": "✨ 표준 스택 권장",
    "reason": "ECS + ALB + RDS Multi-AZ + Terraform: 중급의 최적 학습 경로입니다",
  },
  "team.language.node_express": {
    "badge": "⭐ 실시간/이커머스 권장",
    "reason": "비동기 논블로킹: WebSocket·고동시성 API 최적. 프론트 팀과 언어 공유 가능",
  },
  "team.ops_model.managed": {
    "badge": "✨ 소규모/MVP 권장",
    "reason": "AWS 관리형 서비스 최대 활용. 서버 패치·백업을 AWS에 위임하세요",
  },
  "team.team_size.small": {
    "badge": "✨ 소규모 스타트업 적정",
    "reason": "ECS Fargate로 서버 관리 없이 팀 전원이 서비스 개발에 집중하세요",
  },
  "team.team_size.solo": {
    "badge": "✨ 1인 MVP 최적",
    "reason": "Lambda + Aurora Serverless + Cognito: 서버 0대 운영 가능한 스택",
  },
}
`;

exports[`getRecommendations snapshots > eks_full (en) 1`] = `
{
  "appstack.api_gateway_impl.kong": {
    "badge": "✨ Recommended for large API platforms",
    "reason": "Kong: Developer portal, plugins, multi-tenant Rate Limiting. B2B API platform standard",
  },
  "appstack.api_gateway_impl.spring_gateway": {
    "badge": "✨ Recommended for Spring Boot teams",
    "reason": "Spring Cloud Gateway: Spring ecosystem integration. Built-in Circuit Breaker and Rate Limiter. Natural choice for Java teams",
  },
  "appstack.api_versioning.header": {
    "badge": "✨ Header versioning",
    "reason": "Accept: application/v2+json: Clean URLs but CDN cache must include version header",
  },
  "appstack.api_versioning.subdomain": {
    "badge": "✨ Fully isolated version management",
    "reason": "v2.api.example.com: Fully independent per version. Client migration management for large B2B APIs",
  },
  "appstack.api_versioning.url_path": {
    "badge": "⭐ Industry standard",
    "reason": "URL path /v1/ /v2/: Most intuitive, cacheable, easy log analysis. Choice of 99% of services",
  },
  "appstack.protocol.graphql": {
    "badge": "✨ Optimal for complex data queries",
    "reason": "GraphQL: Clients request only the data they need. No over-fetching. Faster frontend development",
  },
  "appstack.protocol.grpc": {
    "badge": "✨ High-performance internal communication",
    "reason": "gRPC: Internal communication several times faster than REST with Protobuf serialization. Low-bandwidth IoT device communication",
  },
  "appstack.protocol.mixed": {
    "badge": "✨ External REST + internal gRPC",
    "reason": "External APIs use REST (compatibility), internal microservices communication uses gRPC (performance). Role separation",
  },
  "appstack.service_discovery.k8s_dns": {
    "badge": "⭐ EKS default",
    "reason": "CoreDNS: Built into K8s. Auto-discovery by service name. Works without additional configuration",
  },
  "cicd.deploy_strategy.bluegreen": {
    "badge": "⭐ Required for high availability/payment",
    "reason": "Blue/Green: Instant rollback to previous version within 1 minute if new version has issues / Performance first: Blue/Green enables instant rollback to previous version within 1 minute. Maximizes service stability",
  },
  "cicd.deploy_strategy.canary": {
    "badge": "✨ Risk minimization for large scale",
    "reason": "Canary: Only 5% of traffic to new version. Gradual rollout after validation with real users",
  },
  "cicd.env_count.four": {
    "badge": "✨ Large-scale/compliance",
    "reason": "Dev->Stage->PreProd->Prod: Separate environment for performance testing. PCI DSS environment separation requirement",
  },
  "cicd.env_count.three": {
    "badge": "⭐ Stage env prevents 70% of production incidents",
    "reason": "Performance first: Pre-validate in production-like Stage with Dev->Stage->Prod. Drastically reduces production incidents",
  },
  "cicd.iac.cfn": {
    "badge": "✨ Fully AWS-native",
    "reason": "CloudFormation StackSets: Bulk deploy identical templates to dozens of accounts. Organizations integration",
  },
  "cicd.pipeline.gitlab": {
    "badge": "✨ Secure enterprise environment",
    "reason": "GitLab CI: On-premises installation available. For financial/public sectors where code must not leave external servers",
  },
  "compliance.cert.gdpr": {
    "badge": "⭐ Legal obligation for EU users",
    "reason": "EU user data protection + right to be forgotten are legal obligations. EU region storage is simplest, but SCCs allow non-EU regions",
  },
  "compliance.cert.isms": {
    "badge": "✨ Enterprise contract credibility",
    "reason": "ISMS certification becomes a competitive advantage in domestic enterprise contracts",
  },
  "compliance.cert.sox": {
    "badge": "✨ SaaS for US publicly traded companies",
    "reason": "SOX audit compliance needed if providing ERP/financial SaaS to US publicly traded clients",
  },
  "compliance.encryption.strict": {
    "badge": "⭐ Required for compliance",
    "reason": "PCI/HIPAA/SOX: CMK + CloudTrail key usage auditing is a mandatory audit item",
  },
  "compliance.network_iso.private": {
    "badge": "⭐ Required for compliance",
    "reason": "Access AWS services without internet via VPC Endpoints. Meets PCI DSS network isolation requirements",
  },
  "compute.arch_pattern.container": {
    "badge": "⭐ Standard for most services",
    "reason": "Environment consistency with Docker containers. Zero server management with ECS Fargate. AWS recommended default",
  },
  "compute.arch_pattern.vm": {
    "badge": "✨ High-performance/specialized workloads",
    "reason": "Choose only when GPU or specialized instances are needed, like ML inference or game servers",
  },
  "compute.compute_node.ec2_node": {
    "badge": "💰 Large-scale cost savings",
    "reason": "40-60% cost savings vs Fargate when managing EC2 nodes directly. Operations expertise required",
  },
  "compute.compute_node.mixed": {
    "badge": "✨ Cost-stability balance",
    "reason": "Base tasks on EC2, scale-out on Fargate. Auto-distributed via ECS Capacity Provider",
  },
  "compute.orchestration.eks": {
    "badge": "⭐ Maximum flexibility and performance control",
    "reason": "Karpenter + KEDA + Argo CD: Manage hundreds of services on a single unified platform / Performance first: Fine-grained control over node types and scaling with EKS + Karpenter. Large-scale traffic optimization",
  },
  "compute.scaling.ecs_asg": {
    "badge": "⭐ Default for most services",
    "reason": "Auto-scale at 70% CPU. Settings of min:2 max:10 are sufficient. Simplest and most stable",
  },
  "cost.commitment.1yr": {
    "badge": "💰 Savings for stable services",
    "reason": "40% savings with 1-year RI. Effective for cost structure improvement at Series A-B stage",
  },
  "cost.commitment.3yr": {
    "badge": "💰 Maximum savings",
    "reason": "3-year Savings Plans: Up to 72% savings. Only for mature services with confirmed direction",
  },
  "cost.spot_usage.partial": {
    "badge": "💰 Use Spot for background workers",
    "reason": "Main API on On-Demand, background tasks (reports, notifications, aggregation) on Spot for savings. Achieve both stability and cost optimization",
  },
  "data.cache.redis": {
    "badge": "⭐ Required for mid-to-large services",
    "reason": "ElastiCache Redis: 70% DB load reduction. Industry standard for session, product, and cart caching",
  },
  "data.db_ha.global": {
    "badge": "⭐ Global/ultra-high availability",
    "reason": "Aurora Global: Cross-region replication under 1 second. Manual failover within 1-5 minutes during full region failure",
  },
  "data.db_ha.multi_az_read": {
    "badge": "⭐ Required for high availability/e-commerce",
    "reason": "Auto-failover + dedicated read replicas. 2x performance for services where reads are 70%+ of all queries",
  },
  "data.primary_db.aurora_pg": {
    "badge": "⭐ Standard for SaaS/B2B",
    "reason": "Tenant data isolation with PostgreSQL Row-Level Security. Flexible schema with JSON support",
  },
  "data.primary_db.documentdb": {
    "badge": "✨ MongoDB migration",
    "reason": "Migrate existing MongoDB code to AWS managed without changes. MongoDB 5.0 compatible",
  },
  "data.primary_db.dynamodb": {
    "badge": "⭐ Required for high-performance/IoT",
    "reason": "Tens of thousands of reads/writes per second + Auto Scaling. Optimal for atomic ticket inventory processing",
  },
  "data.primary_db.neptune": {
    "badge": "✨ Relationship-centric data",
    "reason": "Social networks, fraud detection, recommendation engines. Optimized for exploring data relationships",
  },
  "data.primary_db.rds_mysql": {
    "badge": "⚠️ Aurora recommended for high availability",
    "reason": "Aurora MySQL recommended for 99.95%+ availability targets. Faster failover than RDS MySQL + up to 15 Read Replicas",
  },
  "data.primary_db.rds_pg": {
    "badge": "⚠️ Aurora recommended for high availability",
    "reason": "Aurora recommended for 99.95%+ availability targets. Faster failover than RDS (30s vs minutes) + auto storage scaling",
  },
  "data.search.no": {
    "badge": "✨ Search unnecessary",
    "reason": "DB index lookups are sufficient. LIKE queries are also viable under 1M records",
  },
  "data.search.opensearch": {
    "badge": "⭐ Recommended for SaaS search/audit",
    "reason": "Per-tenant data search and audit log analysis. Unified operations monitoring with Kibana dashboards",
  },
  "data.storage.none": {
    "badge": "✨ File storage unnecessary",
    "reason": "DB alone is sufficient. Just attach S3 when image/file uploads are needed later",
  },
  "data.storage.s3": {
    "badge": "⭐ File storage standard",
    "reason": "S3 offers unlimited scaling + 99.999999999% durability. S3 is the default for all files",
  },
  "edge.cdn.global": {
    "badge": "⭐ Required for global services",
    "reason": "Global Accelerator + CloudFront: Sub-50ms response from edge locations worldwide",
  },
  "edge.dns.geoloc": {
    "badge": "✨ GDPR/data sovereignty compliance",
    "reason": "Force-route regional users to specific regions based on local legal requirements",
  },
  "edge.dns.latency": {
    "badge": "⭐ Required for global services",
    "reason": "Latency-based routing + health checks included: Automatically connects users to the nearest region",
  },
  "edge.waf.bot": {
    "badge": "⭐ Stability via bot attack defense",
    "reason": "Performance first: Block malicious traffic with Bot Control. Guarantee stable responses for legitimate users",
  },
  "edge.waf.shield": {
    "badge": "⭐ Required for high availability/financial",
    "reason": "DDoS defense SLA + 24/7 DDoS Response Team (DRT). Service maintained during attacks. Financial compliance requirement",
  },
  "integration.api_type.api_gateway": {
    "badge": "✨ Recommended for serverless/IoT",
    "reason": "Direct Lambda integration + Rate Limiting + API key management. Also useful for IoT device authentication",
  },
  "integration.api_type.both": {
    "badge": "✨ Large-scale composite API",
    "reason": "External APIs use API Gateway (Rate Limit), internal service-to-service uses ALB (low cost)",
  },
  "integration.auth.selfmgd": {
    "badge": "⚠️ Self-managed auth SPOF risk",
    "reason": "Self-managed auth server is a SPOF — all service login fails on outage. Consider Cognito/SSO",
  },
  "integration.auth.sso": {
    "badge": "⭐ Required for B2B SaaS",
    "reason": "Integrate client accounts via SAML/OIDC. Departed employee access revocation handled automatically by client IT team",
  },
  "integration.batch_workflow.eventbridge_sch": {
    "badge": "✨ Standard for scheduled batch",
    "reason": "EventBridge Scheduler: Daily early-morning settlement, monthly invoicing. More reliable than Cron",
  },
  "integration.batch_workflow.none": {
    "badge": "✨ Batch unnecessary",
    "reason": "Real-time processing alone is sufficient. Add EventBridge Scheduler when settlement/reports are needed later",
  },
  "integration.queue_type.amazon_mq": {
    "badge": "✨ On-premises MQ migration",
    "reason": "Migrate existing ActiveMQ/RabbitMQ JMS/AMQP code as-is. SQS recommended for new projects",
  },
  "integration.queue_type.eventbridge": {
    "badge": "✨ Recommended for event routing",
    "reason": "200+ AWS service integrations. Minimize inter-service coupling with event rule-based routing",
  },
  "integration.queue_type.msk": {
    "badge": "✨ Large-scale Kafka standard",
