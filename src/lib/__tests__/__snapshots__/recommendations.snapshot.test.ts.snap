exports[`getRecommendations snapshots > compliance (en) 1`] = `
{
  "appstack.api_gateway_impl.alb_only": {
    "badge": "⭐ Standard for most services",
    "reason": "ALB alone is sufficient. Same routing capabilities without API Gateway cost",
  },
  "appstack.api_versioning.url_path": {
    "badge": "⭐ Industry standard",
    "reason": "URL path /v1/ /v2/: Most intuitive, cacheable, easy log analysis. Choice of 99% of services",
  },
  "appstack.protocol.rest": {
    "badge": "⭐ Standard for most services",
    "reason": "REST HTTP/JSON: Supported by browsers, apps, and third parties. No learning curve. Default choice",
  },
  "appstack.schema_registry.none": {
    "badge": "✨ Unnecessary for simple services",
    "reason": "No message schema management needed. REST API JSON + OpenAPI spec is sufficient",
  },
  "appstack.service_discovery.cloud_map": {
    "badge": "⭐ ECS standard",
    "reason": "AWS Cloud Map: Auto-register ECS services. Name-based communication via Route53 private DNS",
  },
  "cicd.deploy_strategy.bluegreen": {
    "badge": "⭐ Required for high availability/payment",
    "reason": "Blue/Green: Instant rollback to previous version within 1 minute if new version has issues",
  },
  "cicd.env_count.four": {
    "badge": "✨ Large-scale/compliance",
    "reason": "Dev->Stage->PreProd->Prod: Separate environment for performance testing. PCI DSS environment separation requirement",
  },
  "cicd.env_count.three": {
    "badge": "⭐ Production service standard",
    "reason": "Dev->Stage->Prod: Verify in production-like Stage before deploying. Prevents 70% of production incidents",
  },
  "cicd.iac.terraform": {
    "badge": "⭐ Industry standard for mid-to-large scale",
    "reason": "De facto standard for multi-account/multi-region management. Manage non-AWS services the same way",
  },
  "cicd.monitoring.cloudwatch": {
    "badge": "⭐ AWS default monitoring",
    "reason": "CloudWatch: Integrated logs, metrics, and alarms without additional setup. Default choice for most services",
  },
  "cicd.monitoring.datadog": {
    "badge": "✨ Unified APM platform",
    "reason": "Datadog: Logs, metrics, and traces in a single UI. Powerful but expensive",
  },
  "cicd.monitoring.xray": {
    "badge": "✨ Distributed tracing recommended",
    "reason": "X-Ray: Visualize request flow between microservices. Quickly identify bottlenecks and error causes",
  },
  "cicd.pipeline.gitlab": {
    "badge": "✨ Secure enterprise environment",
    "reason": "GitLab CI: On-premises installation available. For financial/public sectors where code must not leave external servers",
  },
  "compliance.cert.pci": {
    "badge": "⚠️ Review for payment services",
    "reason": "PCI DSS required for direct card processing. Scope reduces when delegating to payment gateway since card data never touches your servers",
  },
  "compliance.encryption.strict": {
    "badge": "⭐ Required for compliance",
    "reason": "PCI/HIPAA/SOX: CMK + CloudTrail key usage auditing is a mandatory audit item",
  },
  "compliance.network_iso.private": {
    "badge": "⭐ Required for compliance",
    "reason": "Access AWS services without internet via VPC Endpoints. Meets PCI DSS network isolation requirements",
  },
  "compute.arch_pattern.container": {
    "badge": "⭐ Standard for most services",
    "reason": "Environment consistency with Docker containers. Zero server management with ECS Fargate. AWS recommended default",
  },
  "compute.arch_pattern.vm": {
    "badge": "✨ High-performance/specialized workloads",
    "reason": "Choose only when GPU or specialized instances are needed, like ML inference or game servers",
  },
  "compute.compute_node.ec2_node": {
    "badge": "💰 Large-scale cost savings",
    "reason": "40-60% cost savings vs Fargate when managing EC2 nodes directly. Operations expertise required",
  },
  "compute.compute_node.mixed": {
    "badge": "✨ Cost-stability balance",
    "reason": "Base tasks on EC2, scale-out on Fargate. Auto-distributed via ECS Capacity Provider",
  },
  "compute.orchestration.eks": {
    "badge": "✨ Large-scale fine-grained control",
    "reason": "Karpenter + KEDA + Argo CD: Manage hundreds of services on a single unified platform",
  },
  "compute.scaling.scheduled": {
    "badge": "⭐ Required for event services",
    "reason": "Scheduled scale-out 10 min before event. CPU-based scaling reacts after the spike starts, which is too late",
  },
  "cost.commitment.none": {
    "badge": "⭐ Essential when flexibility is needed",
    "reason": "Avoid commitments if service direction may change. On-Demand flexibility is more valuable",
  },
  "cost.priority.balanced": {
    "badge": "⭐ Growth-stage standard",
    "reason": "On-Demand + 1-year RI mix + Spot batch utilization. 30-40% savings without performance degradation",
  },
  "cost.priority.perf_first": {
    "badge": "✨ Consider for transactional services",
    "reason": "1 hour payment outage loss > performance investment cost. Removing bottlenecks has higher ROI than cost cutting",
  },
  "cost.spot_usage.no": {
    "badge": "⭐ Required for transactional/realtime services",
    "reason": "No Spot for payment/ticketing/chat servers. Server interruption causes transaction loss",
  },
  "data.cache.memorydb": {
    "badge": "✨ Durability required",
    "reason": "When cache data loss is business-critical. ~20% more than ElastiCache but zero data loss",
  },
  "data.cache.redis": {
    "badge": "⭐ Required for mid-to-large services",
    "reason": "ElastiCache Redis: 70% DB load reduction. Industry standard for session, product, and cart caching",
  },
  "data.db_ha.multi_az_read": {
    "badge": "⭐ Required for high availability/e-commerce",
    "reason": "Auto-failover + dedicated read replicas. 2x performance for services where reads are 70%+ of all queries",
  },
  "data.primary_db.aurora_mysql": {
    "badge": "⭐ Standard for e-commerce/general services",
    "reason": "Orders, payments, members: Aurora MySQL Serverless v2. Based on AWS e-commerce reference architecture",
  },
  "data.primary_db.documentdb": {
    "badge": "✨ MongoDB migration",
    "reason": "Migrate existing MongoDB code to AWS managed without changes. MongoDB 5.0 compatible",
  },
  "data.primary_db.neptune": {
    "badge": "✨ Relationship-centric data",
    "reason": "Social networks, fraud detection, recommendation engines. Optimized for exploring data relationships",
  },
  "data.primary_db.rds_mysql": {
    "badge": "⚠️ Aurora recommended for high availability",
    "reason": "Aurora MySQL recommended for 99.95%+ availability targets. Faster failover than RDS MySQL + up to 15 Read Replicas",
  },
  "data.primary_db.rds_pg": {
    "badge": "⚠️ Aurora recommended for high availability",
    "reason": "Aurora recommended for 99.95%+ availability targets. Faster failover than RDS (30s vs minutes) + auto storage scaling",
  },
  "data.search.opensearch": {
    "badge": "⭐ Required for marketplace",
    "reason": "Korean morphological analysis + relevance ranking + facet filtering. Search quality impossible to achieve with DB alone",
  },
  "data.storage.s3": {
    "badge": "⭐ File storage standard",
    "reason": "S3 offers unlimited scaling + 99.999999999% durability. S3 is the default for all files",
  },
  "edge.cdn.yes": {
    "badge": "⭐ Default for all external services",
    "reason": "CloudFront: Static file cache + origin protection + automatic HTTPS. Benefits outweigh costs",
  },
  "edge.dns.health": {
    "badge": "⭐ Required for high availability",
    "reason": "Route53 health checks: Automatic DNS failover upon server failure detection. Last line of defense for 99.95% availability",
  },
  "edge.waf.bot": {
    "badge": "⭐ Required for e-commerce/ticketing",
    "reason": "Fair first-come-first-served is impossible without blocking macro bots. Bots account for 70-90% of event-day traffic",
  },
  "edge.waf.shield": {
    "badge": "⭐ Required for high availability/financial",
    "reason": "DDoS defense SLA + 24/7 DDoS Response Team (DRT). Service maintained during attacks. Financial compliance requirement",
  },
  "integration.api_type.alb": {
    "badge": "⭐ Default for most services",
    "reason": "ALB alone is sufficient. API Gateway adds unnecessary cost and complexity",
  },
  "integration.auth.selfmgd": {
    "badge": "✨ Compliance custom authentication",
    "reason": "Choose only when PCI/HIPAA has special requirements. Last resort when Cognito can't solve it / Self-managed auth server is a SPOF — all service login fails on outage. Consider Cognito/SSO",
  },
  "integration.batch_workflow.aws_batch": {
    "badge": "⭐ Required for large-volume batch",
    "reason": "ML training, settlement, large data transformation: 70% cost savings with Spot + Auto Scaling",
  },
  "integration.batch_workflow.ecs_scheduled": {
    "badge": "✨ Post-event batch",
    "reason": "Run settlement and statistics aggregation as ECS Tasks after events. Reuse ECS cluster",
  },
  "integration.batch_workflow.step_functions": {
    "badge": "✨ Complex workflows",
    "reason": "Complex state management for order-payment-inventory-shipping. Visual workflows + automated retries",
  },
  "integration.queue_type.sns": {
    "badge": "✨ Standard for multi-system notifications",
    "reason": "Deliver order completion events simultaneously to inventory, shipping, and analytics systems. Fan-out pattern basics",
  },
  "integration.queue_type.sqs": {
    "badge": "⭐ Standard for order/payment processing",
    "reason": "SQS FIFO: Guaranteed order sequence + exactly-once processing. AWS e-commerce reference standard",
  },
  "integration.sync_async.async": {
    "badge": "⭐ Required for transactional/event services",
    "reason": "Order-payment-inventory-shipping chain: Fault isolation via async separation. AWS standard for payment services",
  },
  "network.account_structure.org": {
    "badge": "⭐ Required for large-scale/compliance",
    "reason": "Organizations + Control Tower: Enforce security policies across all accounts with SCPs. ISMS audit compliance",
  },
  "network.az_count.3az": {
    "badge": "⭐ Required for high availability/compliance",
    "reason": "PCI DSS/HIPAA recommended. Service survives complete AZ failure. Achieves 99.95-99.99%",
  },
  "network.hybrid.dx": {
    "badge": "⭐ Required for large-scale/security",
    "reason": "Direct Connect: Reliable connection via dedicated physical line. On-premises DB integration or high-volume transfer",
  },
  "network.hybrid.no": {
    "badge": "✨ Public cloud only",
    "reason": "No on-premises connection needed. Maintain simple architecture without VPN setup",
  },
  "network.nat_strategy.endpoint": {
    "badge": "💰 Large-scale cost savings",
    "reason": "Route S3/DynamoDB traffic directly without NAT GW. Saves hundreds of dollars/month for high-volume services",
  },
  "network.nat_strategy.per_az": {
    "badge": "⭐ Required for high availability",
    "reason": "Independent NAT GW per AZ: One AZ's NAT failure doesn't affect other AZs",
  },
  "network.network_firewall.network_firewall": {
    "badge": "⭐ Recommended for multi-account/compliance",
    "reason": "Centralized VPC-to-VPC traffic inspection via Transit Gateway Inspection VPC pattern. IDS/IPS + domain filtering",
  },
  "network.subnet_tier.3tier": {
    "badge": "⭐ Required for compliance",
    "reason": "Public + Private + Isolated (DB-only): Meets PCI DSS CDE isolation, HIPAA data protection requirements",
  },
  "platform.cluster_strategy.multi_cluster": {
    "badge": "✨ When environment/team isolation is needed",
    "reason": "Prod/Stage/Dev cluster separation: Mistakes don't affect Prod. Meets ISMS environment separation",
  },
  "platform.gitops.argocd": {
    "badge": "⭐ EKS GitOps standard",
    "reason": "Git as the source of truth. Deploy history, drift detection, visual UI. De facto standard for EKS GitOps",
  },
  "platform.gitops.flux": {
    "badge": "✨ Helm-centric deployment environment",
    "reason": "If Helm chart-based deployments are primary, Flux is more natural and lightweight",
  },
  "platform.ingress.alb_controller": {
    "badge": "⭐ AWS-native standard",
    "reason": "Auto ALB creation + WAF/Shield integration. Most natural choice in AWS environments",
  },
  "platform.ingress.nginx": {
    "badge": "✨ When advanced routing is needed",
    "reason": "Choose when complex URL redirects, rewrites, or Lua scripts are needed",
  },
  "platform.k8s_backup.git_only": {
    "badge": "✨ Sufficient for small scale",
    "reason": "Velero unnecessary if redeployable via IaC + GitOps. Use DB backups for important data",
  },
  "platform.k8s_backup.velero": {
    "badge": "⭐ Required for production clusters",
    "reason": "Full cluster backup including PVCs. Conduct recovery tests quarterly",
  },
  "platform.k8s_monitoring.prometheus_grafana": {
    "badge": "⭐ EKS open-source standard",
    "reason": "Install kube-prometheus-stack at once. Thousands of community-provided Grafana dashboards",
  },
  "platform.k8s_secrets.external_secrets": {
    "badge": "✨ Existing K8s Secret compatible",
    "reason": "ESO: Auto-sync Secrets Manager to K8s Secrets. Adopt without existing app code changes",
  },
  "platform.k8s_secrets.native": {
    "badge": "✨ Simple start for small scale",
    "reason": "K8s Secret Base64: Simple but etcd encryption is required. Sufficient for small internal services",
  },
  "platform.k8s_secrets.secrets_csi": {
    "badge": "⭐ Production standard",
    "reason": "Auto-mount AWS Secrets Manager secrets to Pods. 30-day auto-rotation + CloudTrail auditing",
  },
  "platform.network_policy.cilium": {
    "badge": "✨ When high security/performance is needed",
    "reason": "eBPF-based L7 policies + Hubble observability. When fine-grained network policy control is needed",
  },
  "platform.network_policy.vpc_cni": {
    "badge": "⭐ EKS default standard",
    "reason": "AWS VPC CNI: Direct VPC IP assignment to Pods. Simplest communication with AWS services. Default choice",
  },
  "platform.node_provisioner.karpenter": {
    "badge": "⭐ New EKS standard",
    "reason": "2-3x faster node provisioning vs Cluster Autoscaler. Automatic Spot mix management",
  },
  "platform.pod_security.kyverno": {
    "badge": "⭐ Recommended for compliance",
    "reason": "Write policies in YAML. Forbid latest image tags, enforce resource limits. Easier than Rego",
  },
  "platform.service_mesh.none": {
    "badge": "⭐ Sufficient for most EKS services",
    "reason": "Network Policy + mTLS is sufficient without Service Mesh. Minimize operational complexity",
  },
  "platform.service_mesh.vpc_lattice": {
    "badge": "⭐ Latest service mesh",
    "reason": "App Mesh (2026 EOL) replacement. Works with all compute (ECS/EKS/Lambda). Beginner-friendly",
  },
  "scale.data_volume.gb": {
    "badge": "✨ Ideal for general services",
    "reason": "A single RDS/Aurora instance is sufficient for years. Index design is the performance key",
  },
  "scale.data_volume.tb": {
    "badge": "✨ Ideal for production services",
    "reason": "Use S3 Intelligent-Tiering to automatically store older data at lower cost",
  },
  "scale.dau.large": {
    "badge": "⭐ Architecture design needed",
    "reason": "DAU 1M is the point to consider microservices migration + Aurora Global + EKS adoption",
  },
  "scale.peak_rps.high": {
    "badge": "✨ Cache becomes essential",
    "reason": "1000+ RPS: Direct DB queries without Redis cache will make the DB a bottleneck",
  },
  "scale.traffic_pattern.spike": {
    "badge": "⭐ Must-check for event services",
    "reason": "Flash sales/launches: Set Scheduled Scaling 10 minutes before the event",
  },
  "slo.availability.99.95": {
    "badge": "⭐ Recommended for payment/B2B SaaS",
    "reason": "Under 4.4 hours/year downtime. Achieved with 3 AZs + Aurora Multi-AZ + Route53 health checks",
  },
  "slo.availability.99.99": {
    "badge": "⭐ Large-scale financial/payment services",
    "reason": "Under 53 min/year. Requires 3 AZs + Aurora Global + Multi-Region + fully automated recovery",
  },
  "slo.region.dr": {
    "badge": "✨ Recommended for large transactional services",
    "reason": "Prepare for full region failure with Aurora Global + Route53 Failover. RPO under 1 second",
  },
  "slo.rpo.zero": {
    "badge": "⭐ Required for financial transactions",
    "reason": "Aurora 4/6 write quorum guarantees committed writes + SQS FIFO exactly-once processing. Zero data loss",
  },
  "slo.rto.lt1min": {
    "badge": "⭐ Required for financial/payment",
    "reason": "Full recovery automation required. Achievable only with auto-failover within 30s without human intervention",
  },
  "team.cloud_exp.senior": {
    "badge": "⭐ Required at this scale",
    "reason": "EKS + multi-account + CDK: Operating without advanced skills risks major outages",
  },
  "team.language.mixed": {
    "badge": "✨ Optimal language per service",
    "reason": "Microservices: Choose the optimal language per service. However, be cautious of team expertise dilution",
  },
  "team.language.node_express": {
    "badge": "⭐ Recommended for realtime/e-commerce",
    "reason": "Async non-blocking: Optimal for WebSocket and high-concurrency APIs. Shared language with frontend team",
  },
  "team.ops_model.devops": {
    "badge": "✨ Growth-stage startup standard",
    "reason": "Dev team handles deployment. GitHub Actions + CloudWatch automation is sufficient",
  },
  "team.ops_model.separate": {
    "badge": "✨ Enterprise/compliance environment",
    "reason": "Separate dev/ops for change management processes. Meets ISMS/SOX audit requirements",
  },
  "team.team_size.large": {
    "badge": "⭐ Required for large-scale services",
    "reason": "Running EKS + multi-account without a dedicated SRE/infra team carries high outage risk",
  },
  "team.team_size.medium": {
    "badge": "✨ Ideal for growth-stage teams",
    "reason": "A scale where 1-2 part-time DevOps can manage an ECS + Terraform stack",
  },
}
`;

