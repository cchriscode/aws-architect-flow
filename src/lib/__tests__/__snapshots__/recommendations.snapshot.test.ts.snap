  },
  "platform.k8s_secrets.native": {
    "badge": "✨ Simple start for small scale",
    "reason": "K8s Secret Base64: Simple but etcd encryption is required. Sufficient for small internal services",
  },
  "platform.k8s_secrets.secrets_csi": {
    "badge": "⭐ Production standard",
    "reason": "Auto-mount AWS Secrets Manager secrets to Pods. 30-day auto-rotation + CloudTrail auditing",
  },
  "platform.network_policy.vpc_cni": {
    "badge": "⭐ EKS default standard",
