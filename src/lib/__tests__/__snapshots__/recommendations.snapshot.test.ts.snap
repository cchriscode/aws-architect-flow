// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`getRecommendations snapshots > b2b_saas (en) 1`] = `
{
  "appstack.api_gateway_impl.spring_gateway": {
    "badge": "✨ Recommended for Spring Boot teams",
    "reason": "Spring Cloud Gateway: Spring ecosystem integration. Built-in Circuit Breaker and Rate Limiter. Natural choice for Java teams",
  },
  "appstack.api_versioning.header": {
    "badge": "✨ Header versioning",
    "reason": "Accept: application/v2+json: Clean URLs but CDN cache must include version header",
  },
  "appstack.api_versioning.url_path": {
    "badge": "⭐ Industry standard",
    "reason": "URL path /v1/ /v2/: Most intuitive, cacheable, easy log analysis. Choice of 99% of services",
  },
  "appstack.protocol.graphql": {
    "badge": "✨ Optimal for complex data queries",
    "reason": "GraphQL: Clients request only the data they need. No over-fetching. Faster frontend development",
  },
  "appstack.protocol.rest": {
    "badge": "⭐ Standard for most services",
    "reason": "REST HTTP/JSON: Supported by browsers, apps, and third parties. No learning curve. Default choice",
  },
  "appstack.schema_registry.none": {
    "badge": "✨ Unnecessary for simple services",
    "reason": "No message schema management needed. REST API JSON + OpenAPI spec is sufficient",
  },
  "appstack.service_discovery.k8s_dns": {
    "badge": "⭐ EKS default",
    "reason": "CoreDNS: Built into K8s. Auto-discovery by service name. Works without additional configuration",
  },
  "cicd.deploy_strategy.bluegreen": {
    "badge": "⭐ Required for high availability/payment",
    "reason": "Blue/Green: Instant rollback to previous version within 1 minute if new version has issues",
  },
  "cicd.env_count.three": {
    "badge": "⭐ Production service standard",
    "reason": "Dev->Stage->Prod: Verify in production-like Stage before deploying. Prevents 70% of production incidents",
  },
  "cicd.iac.terraform": {
    "badge": "⭐ Industry standard for mid-to-large scale",
    "reason": "De facto standard for multi-account/multi-region management. Manage non-AWS services the same way",
  },
  "cicd.pipeline.github": {
    "badge": "⭐ Standard for small-to-mid scale",
    "reason": "GitHub Actions: Fastest setup. 2000 free minutes/month. Largest open-source action ecosystem",
  },
  "compliance.encryption.standard": {
    "badge": "⭐ Required for personal data services",
    "reason": "Data protection law: Transit + at-rest encryption is a legal obligation. Free with AWS default KMS",
  },
  "compliance.network_iso.strict": {
    "badge": "⭐ Required for personal data services",
    "reason": "App+DB fully isolated in private subnets. No direct DB access from the internet",
  },
  "compute.arch_pattern.container": {
    "badge": "⭐ Standard for most services",
    "reason": "Environment consistency with Docker containers. Zero server management with ECS Fargate. AWS recommended default",
  },
  "compute.compute_node.mixed": {
    "badge": "✨ Cost-stability balance",
    "reason": "Base tasks on EC2, scale-out on Fargate. Auto-distributed via ECS Capacity Provider",
  },
  "compute.orchestration.eks": {
    "badge": "✨ Large-scale fine-grained control",
    "reason": "Karpenter + KEDA + Argo CD: Manage hundreds of services on a single unified platform",
  },
  "compute.scaling.ecs_asg": {
    "badge": "⭐ Default for most services",
    "reason": "Auto-scale at 70% CPU. Settings of min:2 max:10 are sufficient. Simplest and most stable",
  },
  "cost.commitment.1yr": {
    "badge": "💰 Savings for stable services",
    "reason": "40% savings with 1-year RI. Effective for cost structure improvement at Series A-B stage",
  },
  "cost.priority.balanced": {
    "badge": "⭐ Growth-stage standard",
    "reason": "On-Demand + 1-year RI mix + Spot batch utilization. 30-40% savings without performance degradation",
  },
  "cost.spot_usage.partial": {
    "badge": "💰 Use Spot for background workers",
    "reason": "Main API on On-Demand, background tasks (reports, notifications, aggregation) on Spot for savings. Achieve both stability and cost optimization",
  },
  "data.cache.redis": {
    "badge": "⭐ Required for mid-to-large services",
    "reason": "ElastiCache Redis: 70% DB load reduction. Industry standard for session, product, and cart caching",
  },
  "data.db_ha.multi_az_read": {
    "badge": "⭐ Required for high availability/e-commerce",
    "reason": "Auto-failover + dedicated read replicas. 2x performance for services where reads are 70%+ of all queries",
  },
  "data.primary_db.aurora_pg": {
    "badge": "⭐ Standard for SaaS/B2B",
    "reason": "Tenant data isolation with PostgreSQL Row-Level Security. Flexible schema with JSON support",
  },
  "data.primary_db.documentdb": {
    "badge": "✨ MongoDB migration",
    "reason": "Migrate existing MongoDB code to AWS managed without changes. MongoDB 5.0 compatible",
  },
  "data.primary_db.neptune": {
    "badge": "✨ Relationship-centric data",
    "reason": "Social networks, fraud detection, recommendation engines. Optimized for exploring data relationships",
  },
  "data.primary_db.rds_mysql": {
    "badge": "⚠️ Aurora recommended for high availability",
    "reason": "Aurora MySQL recommended for 99.95%+ availability targets. Faster failover than RDS MySQL + up to 15 Read Replicas",
  },
  "data.primary_db.rds_pg": {
    "badge": "⚠️ Aurora recommended for high availability",
    "reason": "Aurora recommended for 99.95%+ availability targets. Faster failover than RDS (30s vs minutes) + auto storage scaling",
  },
  "data.search.no": {
    "badge": "✨ Search unnecessary",
    "reason": "DB index lookups are sufficient. LIKE queries are also viable under 1M records",
  },
  "data.search.opensearch": {
    "badge": "⭐ Recommended for SaaS search/audit",
    "reason": "Per-tenant data search and audit log analysis. Unified operations monitoring with Kibana dashboards",
  },
  "data.storage.none": {
    "badge": "✨ File storage unnecessary",
    "reason": "DB alone is sufficient. Just attach S3 when image/file uploads are needed later",
  },
  "data.storage.s3": {
    "badge": "⭐ File storage standard",
    "reason": "S3 offers unlimited scaling + 99.999999999% durability. S3 is the default for all files",
  },
  "edge.cdn.yes": {
    "badge": "⭐ Default for all external services",
    "reason": "CloudFront: Static file cache + origin protection + automatic HTTPS. Benefits outweigh costs",
  },
  "edge.dns.health": {
    "badge": "⭐ Required for high availability",
    "reason": "Route53 health checks: Automatic DNS failover upon server failure detection. Last line of defense for 99.95% availability",
  },
  "edge.waf.basic": {
    "badge": "⭐ Basic security for external services",
    "reason": "Block SQL injection, XSS, LFI. AWS Managed Rules: Ready-to-apply baseline rule sets",
  },
  "integration.api_type.alb": {
    "badge": "⭐ Default for most services",
    "reason": "ALB alone is sufficient. API Gateway adds unnecessary cost and complexity",
  },
  "integration.auth.selfmgd": {
    "badge": "⚠️ Self-managed auth SPOF risk",
    "reason": "Self-managed auth server is a SPOF — all service login fails on outage. Consider Cognito/SSO",
  },
  "integration.auth.sso": {
    "badge": "⭐ Required for B2B SaaS",
    "reason": "Integrate client accounts via SAML/OIDC. Departed employee access revocation handled automatically by client IT team",
  },
  "integration.batch_workflow.eventbridge_sch": {
    "badge": "✨ Standard for scheduled batch",
    "reason": "EventBridge Scheduler: Daily early-morning settlement, monthly invoicing. More reliable than Cron",
  },
  "integration.batch_workflow.none": {
    "badge": "✨ Batch unnecessary",
    "reason": "Real-time processing alone is sufficient. Add EventBridge Scheduler when settlement/reports are needed later",
  },
  "integration.queue_type.eventbridge": {
    "badge": "✨ Recommended for event routing",
    "reason": "200+ AWS service integrations. Minimize inter-service coupling with event rule-based routing",
  },
  "integration.queue_type.sns": {
    "badge": "✨ Standard for multi-system notifications",
    "reason": "Deliver order completion events simultaneously to inventory, shipping, and analytics systems. Fan-out pattern basics",
  },
  "integration.sync_async.mixed": {
    "badge": "✨ Recommended for composite services",
    "reason": "APIs are sync (immediate response), payments/notifications are async. Separated to match each service's nature",
  },
  "network.account_structure.envs": {
    "badge": "⭐ Growth-stage standard",
    "reason": "Just separating the Prod account blocks dev mistakes from affecting production. AWS recommended baseline",
  },
  "network.az_count.2az": {
    "badge": "⭐ Production service standard",
    "reason": "Optimal cost point for 99.9-99.95% availability. AZ failure resilience at the cost of 2 NAT GWs",
  },
  "network.hybrid.vpn": {
    "badge": "✨ B2B office connectivity",
    "reason": "Connect office to AWS with Site-to-Site VPN. Quick setup, low cost. When high bandwidth isn't needed",
  },
  "network.nat_strategy.endpoint": {
    "badge": "💰 Large-scale cost savings",
    "reason": "Route S3/DynamoDB traffic directly without NAT GW. Saves hundreds of dollars/month for high-volume services",
  },
  "network.nat_strategy.per_az": {
    "badge": "⭐ Required for high availability",
    "reason": "Independent NAT GW per AZ: One AZ's NAT failure doesn't affect other AZs",
  },
  "network.network_firewall.none": {
    "badge": "✨ Optional with env separation",
    "reason": "Account separation per environment may be sufficient. Consider adoption for PCI/HIPAA requirements",
  },
  "network.subnet_tier.2tier": {
    "badge": "⭐ Standard for most services",
    "reason": "Public (ALB) + Private (app+DB): Security Groups allow DB access only from app servers",
  },
  "platform.autoscaling_strategy.hpa_only": {
    "badge": "⭐ Default for most EKS services",
    "reason": "CPU-based HPA min:2 max:10: Simplest and most stable K8s scaling method",
  },
  "platform.cluster_strategy.multi_cluster": {
    "badge": "✨ When environment/team isolation is needed",
    "reason": "Prod/Stage/Dev cluster separation: Mistakes don't affect Prod. Meets ISMS environment separation",
  },
  "platform.cluster_strategy.single_ns": {
    "badge": "✨ Suitable for small/single team",
    "reason": "Start with single namespace. Apply separation strategy as teams and services grow",
  },
  "platform.gitops.argocd": {
    "badge": "⭐ EKS GitOps standard",
    "reason": "Git as the source of truth. Deploy history, drift detection, visual UI. De facto standard for EKS GitOps",
  },
  "platform.ingress.alb_controller": {
    "badge": "⭐ AWS-native standard",
    "reason": "Auto ALB creation + WAF/Shield integration. Most natural choice in AWS environments",
  },
  "platform.k8s_backup.git_only": {
    "badge": "✨ Sufficient for small scale",
    "reason": "Velero unnecessary if redeployable via IaC + GitOps. Use DB backups for important data",
  },
  "platform.k8s_monitoring.cloudwatch": {
    "badge": "✨ Recommended for AWS all-in/small scale",
    "reason": "Directly from AWS Console with no additional tools. Just enable Container Insights",
  },
  "platform.k8s_secrets.native": {
    "badge": "✨ Simple start for small scale",
    "reason": "K8s Secret Base64: Simple but etcd encryption is required. Sufficient for small internal services",
  },
  "platform.k8s_secrets.secrets_csi": {
    "badge": "⭐ Production standard",
    "reason": "Auto-mount AWS Secrets Manager secrets to Pods. 30-day auto-rotation + CloudTrail auditing",
  },
  "platform.network_policy.vpc_cni": {
    "badge": "⭐ EKS default standard",
    "reason": "AWS VPC CNI: Direct VPC IP assignment to Pods. Simplest communication with AWS services. Default choice",
  },
  "platform.node_provisioner.cluster_autoscaler": {
    "badge": "✨ Existing cluster compatible",
    "reason": "Keep if already using Cluster Autoscaler. Karpenter recommended for new clusters",
  },
  "platform.node_provisioner.karpenter": {
    "badge": "⭐ New EKS standard",
    "reason": "2-3x faster node provisioning vs Cluster Autoscaler. Automatic Spot mix management",
  },
  "platform.pod_security.psa": {
    "badge": "✨ K8s built-in baseline security",
    "reason": "Block Privileged Pods without additional tools. Sufficient as a starting point",
  },
  "platform.service_mesh.none": {
    "badge": "⭐ Sufficient for most EKS services",
    "reason": "Network Policy + mTLS is sufficient without Service Mesh. Minimize operational complexity",
  },
  "scale.data_volume.gb": {
    "badge": "✨ Ideal for general services",
    "reason": "A single RDS/Aurora instance is sufficient for years. Index design is the performance key",
  },
  "scale.data_volume.tb": {
    "badge": "✨ Ideal for production services",
    "reason": "Use S3 Intelligent-Tiering to automatically store older data at lower cost",
  },
  "scale.dau.medium": {
    "badge": "✨ Ideal for growth-stage services",
    "reason": "DAU 10K-100K: This is the point where Redis caching becomes essential",
  },
  "scale.peak_rps.high": {
    "badge": "✨ Cache becomes essential",
    "reason": "1000+ RPS: Direct DB queries without Redis cache will make the DB a bottleneck",
  },
  "scale.peak_rps.mid": {
    "badge": "✨ Standard web service baseline",
    "reason": "100-1000 RPS: A basic ALB + ECS Fargate setup is sufficient",
  },
  "scale.traffic_pattern.business": {
    "badge": "✨ Business-hours focused pattern",
    "reason": "30-50% cost reduction possible with Scheduled Scaling during nights/weekends",
  },
  "scale.traffic_pattern.steady": {
    "badge": "✨ Typical B2B/subscription pattern",
    "reason": "40% savings with Reserved Instances. Enables predictable cost management",
  },
  "slo.availability.99.95": {
    "badge": "⭐ Recommended for payment/B2B SaaS",
    "reason": "Under 4.4 hours/year downtime. Achieved with 3 AZs + Aurora Multi-AZ + Route53 health checks",
  },
  "slo.rpo.15min": {
    "badge": "⭐ Recommended for transactional services",
    "reason": "Aurora continuous backup (second-level restore) included by default. Sub-second RPO achievable without configuration",
  },
  "slo.rto.lt10min": {
    "badge": "⭐ Recommended for transactional services",
    "reason": "Multi-AZ auto-failover (30s) + RunBook automation. Recovery possible within 10 minutes",
  },
  "team.cloud_exp.senior": {
    "badge": "⭐ Required at this scale",
    "reason": "EKS + multi-account + CDK: Operating without advanced skills risks major outages",
  },
  "team.language.mixed": {
    "badge": "✨ Optimal language per service",
    "reason": "Microservices: Choose the optimal language per service. However, be cautious of team expertise dilution",
  },
  "team.language.spring_boot": {
    "badge": "✨ Recommended for enterprise B2B",
    "reason": "Java Spring Boot: Proven choice in financial, public, and enterprise sectors. Stable JVM performance",
  },
  "team.ops_model.devops": {
    "badge": "✨ Growth-stage startup standard",
    "reason": "Dev team handles deployment. GitHub Actions + CloudWatch automation is sufficient",
  },
  "team.ops_model.separate": {
    "badge": "✨ Enterprise/compliance environment",
    "reason": "Separate dev/ops for change management processes. Meets ISMS/SOX audit requirements",
  },
  "team.team_size.medium": {
    "badge": "✨ Ideal for growth-stage teams",
    "reason": "A scale where 1-2 part-time DevOps can manage an ECS + Terraform stack",
  },
}
`;

exports[`getRecommendations snapshots > b2b_saas (ko) 1`] = `
{
  "appstack.api_gateway_impl.spring_gateway": {
    "badge": "✨ Spring Boot 팀 권장",
    "reason": "Spring Cloud Gateway: Spring 생태계 통합. Circuit Breaker·Rate Limiter 내장. Java 팀에 자연스러운 선택",
  },
  "appstack.api_versioning.header": {
    "badge": "✨ 헤더 버저닝",
    "reason": "Accept: application/v2+json: URL 깔끔하지만 CDN 캐시에 버전 헤더 포함 필요",
  },
  "appstack.api_versioning.url_path": {
    "badge": "⭐ 업계 표준",
    "reason": "URL 경로 /v1/ /v2/: 가장 직관적·캐시 가능·로그 분석 용이. 99% 서비스의 선택",
  },
  "appstack.protocol.graphql": {
    "badge": "✨ 복잡한 데이터 조회 최적",
    "reason": "GraphQL: 클라이언트가 필요한 데이터만 요청. 오버페칭 없음. 빠른 프론트 개발",
  },
  "appstack.protocol.rest": {
    "badge": "⭐ 대부분 서비스 표준",
    "reason": "REST HTTP/JSON: 브라우저·앱·서드파티 모두 지원. 학습 곡선 없음. 기본 선택",
  },
  "appstack.schema_registry.none": {
    "badge": "✨ 단순 서비스 불필요",
    "reason": "메시지 스키마 관리 불필요. REST API JSON + OpenAPI 스펙으로 충분",
  },
  "appstack.service_discovery.k8s_dns": {
    "badge": "⭐ EKS 기본",
    "reason": "CoreDNS: K8s 내장. 서비스 이름으로 자동 발견. 추가 설정 없이 동작",
  },
  "cicd.deploy_strategy.bluegreen": {
    "badge": "⭐ 고가용성/결제 필수",
    "reason": "Blue/Green: 새 버전 문제 발생 시 1분 내 이전 버전으로 즉시 전환 가능",
  },
  "cicd.env_count.three": {
    "badge": "⭐ 운영 서비스 표준",
    "reason": "Dev->Stage->Prod: Stage에서 프로덕션 환경 검증 후 배포. 운영 사고 70% 방지",
  },
  "cicd.iac.terraform": {
    "badge": "⭐ 중대규모 업계 표준",
    "reason": "멀티 계정·멀티 리전 관리의 사실상 표준. AWS 외 서비스도 동일하게 관리 가능",
  },
  "cicd.pipeline.github": {
    "badge": "⭐ 소~중규모 표준",
    "reason": "GitHub Actions: 가장 빠른 설정. 무료 월 2000분. 오픈소스 액션 생태계 최대",
  },
  "compliance.encryption.standard": {
    "badge": "⭐ 개인정보 서비스 필수",
