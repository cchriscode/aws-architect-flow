    "reason": "Prometheus (metrics) + CloudWatch (logs/alarms): Leverage each tool's strengths",
  },
  "platform.k8s_monitoring.prometheus_grafana": {
    "badge": "⭐ EKS open-source standard",
    "reason": "Install kube-prometheus-stack at once. Thousands of community-provided Grafana dashboards",
  },
  "platform.k8s_secrets.external_secrets": {
    "badge": "✨ Existing K8s Secret compatible",
    "reason": "ESO: Auto-sync Secrets Manager to K8s Secrets. Adopt without existing app code changes",
  },
  "platform.k8s_secrets.native": {
    "badge": "✨ Simple start for small scale",
    "reason": "K8s Secret Base64: Simple but etcd encryption is required. Sufficient for small internal services",
  },
  "platform.k8s_secrets.secrets_csi": {
    "badge": "⭐ Production standard",
    "reason": "Auto-mount AWS Secrets Manager secrets to Pods. 30-day auto-rotation + CloudTrail auditing",
  },
  "platform.network_policy.cilium": {
    "badge": "✨ When high security/performance is needed",
    "reason": "eBPF-based L7 policies + Hubble observability. When fine-grained network policy control is needed",
  },
  "platform.network_policy.vpc_cni": {
    "badge": "⭐ EKS default standard",
    "reason": "AWS VPC CNI: Direct VPC IP assignment to Pods. Simplest communication with AWS services. Default choice",
  },
  "platform.node_provisioner.karpenter": {
    "badge": "⭐ New EKS standard",
    "reason": "2-3x faster node provisioning vs Cluster Autoscaler. Automatic Spot mix management",
  },
  "platform.pod_security.kyverno": {
    "badge": "⭐ Recommended for compliance",
    "reason": "Write policies in YAML. Forbid latest image tags, enforce resource limits. Easier than Rego",
  },
  "platform.pod_security.opa_gatekeeper": {
    "badge": "✨ Complex custom policies",
    "reason": "Unlimited custom policies with Rego language. Standard for large platform teams but high learning cost",
  },
  "platform.service_mesh.istio": {
    "badge": "✨ When full service mesh is needed",
    "reason": "Automated mTLS + fine-grained traffic control. Operations team proficiency required. High learning cost",
  },
  "platform.service_mesh.none": {
    "badge": "⭐ Sufficient for most EKS services",
    "reason": "Network Policy + mTLS is sufficient without Service Mesh. Minimize operational complexity",
  },
  "scale.data_volume.gb": {
    "badge": "✨ Ideal for general services",
    "reason": "A single RDS/Aurora instance is sufficient for years. Index design is the performance key",
  },
  "scale.data_volume.ptb": {
    "badge": "⭐ Large-scale data strategy needed",
    "reason": "S3 data lake + Athena analytics. Automate moving old data to Glacier",
  },
  "scale.data_volume.tb": {
    "badge": "✨ Ideal for production services",
    "reason": "Use S3 Intelligent-Tiering to automatically store older data at lower cost",
  },
  "scale.dau.xlarge": {
    "badge": "⭐ Dedicated infra team required",
    "reason": "At this scale, a single architecture decision can mean millions in monthly cost difference",
  },
  "scale.peak_rps.ultra": {
    "badge": "⭐ Extreme concurrency prep needed",
    "reason": "10K+ RPS: Database/server overload without DynamoDB + Redis + CloudFront combination",
  },
  "scale.traffic_pattern.business": {
    "badge": "✨ Business-hours focused pattern",
    "reason": "30-50% cost reduction possible with Scheduled Scaling during nights/weekends",
  },
  "scale.traffic_pattern.steady": {
    "badge": "✨ Typical B2B/subscription pattern",
    "reason": "40% savings with Reserved Instances. Enables predictable cost management",
  },
  "slo.availability.99.95": {
    "badge": "⭐ Recommended for payment/B2B SaaS",
    "reason": "Under 4.4 hours/year downtime. Achieved with 3 AZs + Aurora Multi-AZ + Route53 health checks",
  },
  "slo.availability.99.99": {
    "badge": "⭐ Large-scale financial/payment services",
    "reason": "Under 53 min/year. Requires 3 AZs + Aurora Global + Multi-Region + fully automated recovery",
  },
  "slo.region.active": {
    "badge": "⭐ Required for global/ultra-high availability",
    "reason": "Lowest global latency with DynamoDB Global Tables + Route53 latency-based routing",
  },
  "slo.rpo.zero": {
    "badge": "⭐ Required for financial transactions",
    "reason": "Aurora 4/6 write quorum guarantees committed writes + SQS FIFO exactly-once processing. Zero data loss",
  },
  "slo.rto.lt1min": {
    "badge": "⭐ Required for financial/payment",
    "reason": "Full recovery automation required. Achievable only with auto-failover within 30s without human intervention",
  },
  "team.cloud_exp.senior": {
    "badge": "⭐ Required at this scale",
    "reason": "EKS + multi-account + CDK: Operating without advanced skills risks major outages",
  },
  "team.language.go": {
    "badge": "✨ High-performance/microservices",
    "reason": "Go: Best compiled language performance + low memory. Suitable for K8s controllers or high-performance APIs",
  },
  "team.language.spring_boot": {
    "badge": "✨ Recommended for enterprise B2B",
    "reason": "Java Spring Boot: Proven choice in financial, public, and enterprise sectors. Stable JVM performance",
  },
  "team.ops_model.separate": {
    "badge": "✨ Enterprise/compliance environment",
    "reason": "Separate dev/ops for change management processes. Meets ISMS/SOX audit requirements",
  },
  "team.team_size.large": {
    "badge": "⭐ Required for large-scale services",
    "reason": "Running EKS + multi-account without a dedicated SRE/infra team carries high outage risk",
  },
}
`;

