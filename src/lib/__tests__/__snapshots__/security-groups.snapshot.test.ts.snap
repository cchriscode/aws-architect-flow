resource "aws_security_group" "lambda" {
  name_prefix = "lambda-"
  vpc_id      = module.vpc.vpc_id
  description = "Lambda Security Group"

  # Lambda: 인바운드 없음 (Lambda는 항상 아웃바운드로만 통신)

  egress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]  # VPC Endpoint 경유 (Secrets Manager, ECR, CloudWatch)
    description = "AWS services via VPC Endpoint"
  }
}
",
  "groups": [
    {
      "color": "#2563eb",
      "desc": "인터넷 → ALB 인바운드. CloudFront IP 또는 0.0.0.0/0",
      "id": "alb_sg",
      "inbound": [
        {
          "from": "0.0.0.0/0 (HTTPS 트래픽)",
          "port": "443",
        },
        {
          "from": "0.0.0.0/0 (HTTP → 443 리다이렉트)",
          "port": "80",
        },
      ],
      "name": "ALB Security Group",
      "outbound": [
        {
          "port": "3000",
          "to": "app_sg (앱 서버로 전달)",
        },
      ],
    },
    {
      "color": "#f59e0b",
      "desc": "Lambda VPC 배치 시 필요. 인바운드 없음(Lambda는 외부 호출 없음)",
      "id": "lambda_sg",
      "inbound": [],
      "name": "Lambda Security Group",
      "outbound": [
        {
          "port": "443",
          "to": "0.0.0.0/0 VPC Endpoint (Secrets Manager, DynamoDB, S3)",
        },
      ],
    },
  ],
  "iac": "terraform",
}
`;

exports[`generateSecurityGroups snapshots > ticketing (en) 1`] = `
{
  "code": "# Terraform -- Full Security Group chain

# CloudFront Managed Prefix List lookup
data "aws_ec2_managed_prefix_list" "cloudfront" {
  name = "com.amazonaws.global.cloudfront.origin-facing"
}

# ── ALB Security Group
resource "aws_security_group" "alb" {
  name_prefix = "alb-"
  vpc_id      = module.vpc.vpc_id
  description = "ALB Security Group"

  ingress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    # CloudFront Managed Prefix List (ID varies by region, verify with describe-managed-prefix-lists)
    prefix_list_ids = [data.aws_ec2_managed_prefix_list.cloudfront.id]
    description = "HTTPS from CloudFront"
  }
  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    # CloudFront Managed Prefix List (ID varies by region, verify with describe-managed-prefix-lists)
    prefix_list_ids = [data.aws_ec2_managed_prefix_list.cloudfront.id]
    description = "HTTP (redirect to HTTPS)"
  }
  egress {
    from_port       = 3000
    to_port         = 3000
    protocol        = "tcp"
    security_groups = [aws_security_group.app.id]
    description     = "ALB to App"
  }
}

# ── Application Security Group
resource "aws_security_group" "app" {
  name_prefix = "app-"
  vpc_id      = module.vpc.vpc_id
  description = "Application Security Group"

  ingress {
    from_port       = 3000
    to_port         = 3000
    protocol        = "tcp"
    security_groups = [aws_security_group.alb.id]
    description     = "ALB to App"
  }

  egress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]  # Via VPC Endpoint (Secrets Manager, ECR, CloudWatch)
    description = "AWS services via VPC Endpoint"
  }
  egress {
    from_port       = 5432
    to_port         = 5432
    protocol        = "tcp"
    security_groups = [aws_security_group.db.id]
    description     = "Application to DB"
  }
  egress {
    from_port       = 6379
    to_port         = 6379
    protocol        = "tcp"
    security_groups = [aws_security_group.cache.id]
    description     = "Application to Redis"
  }
}

# ── DB Security Group
resource "aws_security_group" "db" {
  name_prefix = "db-"
  vpc_id      = module.vpc.vpc_id
  description = "Database SG -- no internet, app/lambda only"

  ingress {
    from_port       = 5432
    to_port         = 5432
    protocol        = "tcp"
    security_groups = [aws_security_group.app.id]
    description     = "From app only"
  }
  # No outbound -- DB only responds (stateful, no explicit allow needed)
}

# ── Cache Security Group
resource "aws_security_group" "cache" {
  name_prefix = "cache-"
  vpc_id      = module.vpc.vpc_id
  description = "ElastiCache SG -- app only"

  ingress {
    from_port       = 6379
    to_port         = 6379
    protocol        = "tcp"
    security_groups = [aws_security_group.app.id]
    description     = "Redis from app only"
  }
}
",
  "groups": [
    {
      "color": "#2563eb",
      "desc": "Internet -> ALB inbound. CloudFront IP or 0.0.0.0/0",
      "id": "alb_sg",
      "inbound": [
        {
          "from": "CloudFront Managed Prefix List (com.amazonaws.global.cloudfront.origin-facing) - HTTPS traffic",
          "port": "443",
        },
        {
          "from": "CloudFront Managed Prefix List - HTTP (redirect to 443)",
          "port": "80",
        },
      ],
      "name": "ALB Security Group",
      "outbound": [
        {
          "port": "3000",
          "to": "app_sg (forward to app servers)",
        },
      ],
    },
    {
      "color": "#059669",
      "desc": "ALB -> app server. App -> DB/cache outbound",
      "id": "app_sg",
      "inbound": [
        {
          "from": "alb_sg (ALB to app)",
          "port": "3000",
        },
      ],
      "name": "App Security Group",
      "outbound": [
        {
          "port": "5432",
          "to": "db_sg (PostgreSQL/Aurora PG)",
        },
        {
          "port": "6379",
          "to": "cache_sg (ElastiCache Redis)",
        },
        {
          "port": "443",
          "to": "443 (VPC Endpoints - Secrets Manager, ECR, CloudWatch)",
        },
      ],
    },
    {
      "color": "#dc2626",
      "desc": "DB accessible from app/Lambda only. Internet access fully blocked",
      "id": "db_sg",
      "inbound": [
        {
          "from": "app_sg (allow access from app servers only)",
          "port": "5432",
        },
      ],
      "name": "Database Security Group",
      "outbound": [],
    },
    {
      "color": "#7c3aed",
      "desc": "Redis accessible from app only. Never expose directly",
      "id": "cache_sg",
      "inbound": [
        {
          "from": "app_sg (allow from app servers only)",
          "port": "6379",
        },
      ],
      "name": "ElastiCache Security Group",
      "outbound": [],
    },
    {
      "color": "#374151",
      "desc": "Admin access only. Allow office IP only",
      "id": "bastion_sg",
      "inbound": [
        {
          "from": "Office static IP/32 (must restrict to specific IP) - SSH/SSM admin access",
          "port": "22",
        },
      ],
      "name": "Bastion / VPN Endpoint Security Group",
      "outbound": [
        {
          "port": "22",
          "to": "app_sg (app server SSH when needed)",
        },
        {
          "port": "5432",
          "to": "db_sg (DB direct query for emergencies)",
        },
      ],
    },
  ],
  "iac": "terraform",
}
`;

exports[`generateSecurityGroups snapshots > ticketing (ko) 1`] = `
{
  "code": "# Terraform -- Security Group 전체 체인

# CloudFront Managed Prefix List 조회
data "aws_ec2_managed_prefix_list" "cloudfront" {
  name = "com.amazonaws.global.cloudfront.origin-facing"
}

# ── ALB Security Group
resource "aws_security_group" "alb" {
  name_prefix = "alb-"
  vpc_id      = module.vpc.vpc_id
  description = "ALB Security Group"

  ingress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    # CloudFront Managed Prefix List (리전별 ID 상이, describe-managed-prefix-lists로 확인)
    prefix_list_ids = [data.aws_ec2_managed_prefix_list.cloudfront.id]
    description = "HTTPS from CloudFront"
  }
  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    # CloudFront Managed Prefix List (리전별 ID 상이, describe-managed-prefix-lists로 확인)
    prefix_list_ids = [data.aws_ec2_managed_prefix_list.cloudfront.id]
    description = "HTTP (redirect to HTTPS)"
  }
  egress {
    from_port       = 3000
    to_port         = 3000
    protocol        = "tcp"
    security_groups = [aws_security_group.app.id]
    description     = "ALB to App"
  }
}

# ── Application Security Group
resource "aws_security_group" "app" {
  name_prefix = "app-"
  vpc_id      = module.vpc.vpc_id
  description = "Application Security Group"

  ingress {
    from_port       = 3000
    to_port         = 3000
    protocol        = "tcp"
    security_groups = [aws_security_group.alb.id]
    description     = "ALB to App"
  }

  egress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]  # VPC Endpoint 경유 (Secrets Manager, ECR, CloudWatch)
    description = "AWS services via VPC Endpoint"
  }
  egress {
    from_port       = 5432
    to_port         = 5432
    protocol        = "tcp"
    security_groups = [aws_security_group.db.id]
    description     = "Application to DB"
  }
  egress {
    from_port       = 6379
    to_port         = 6379
    protocol        = "tcp"
    security_groups = [aws_security_group.cache.id]
    description     = "Application to Redis"
  }
}

# ── DB Security Group
resource "aws_security_group" "db" {
  name_prefix = "db-"
  vpc_id      = module.vpc.vpc_id
  description = "Database SG -- no internet, app/lambda only"

  ingress {
    from_port       = 5432
    to_port         = 5432
    protocol        = "tcp"
    security_groups = [aws_security_group.app.id]
    description     = "From app only"
  }
  # 아웃바운드 없음 -- DB는 응답만 (stateful이므로 별도 허용 불필요)
}

# ── Cache Security Group
resource "aws_security_group" "cache" {
  name_prefix = "cache-"
  vpc_id      = module.vpc.vpc_id
  description = "ElastiCache SG -- app only"

  ingress {
    from_port       = 6379
    to_port         = 6379
    protocol        = "tcp"
    security_groups = [aws_security_group.app.id]
    description     = "Redis from app only"
  }
}
",
  "groups": [
    {
      "color": "#2563eb",
      "desc": "인터넷 → ALB 인바운드. CloudFront IP 또는 0.0.0.0/0",
      "id": "alb_sg",
      "inbound": [
        {
          "from": "CloudFront Managed Prefix List (com.amazonaws.global.cloudfront.origin-facing) - HTTPS 트래픽",
          "port": "443",
        },
        {
          "from": "CloudFront Managed Prefix List - HTTP (→443 리다이렉트)",
          "port": "80",
        },
      ],
      "name": "ALB Security Group",
      "outbound": [
        {
          "port": "3000",
          "to": "app_sg (앱 서버로 전달)",
        },
      ],
    },
    {
      "color": "#059669",
      "desc": "ALB → 앱 서버. 앱 → DB/캐시 아웃바운드",
      "id": "app_sg",
      "inbound": [
        {
          "from": "alb_sg (ALB에서 앱으로)",
          "port": "3000",
        },
      ],
      "name": "App Security Group",
      "outbound": [
        {
          "port": "5432",
          "to": "db_sg (PostgreSQL/Aurora PG)",
        },
        {
          "port": "6379",
          "to": "cache_sg (ElastiCache Redis)",
        },
        {
          "port": "443",
          "to": "443 (VPC Endpoint - Secrets Manager, ECR, CloudWatch)",
        },
      ],
    },
    {
      "color": "#dc2626",
      "desc": "DB는 앱/Lambda에서만 접근. 인터넷 접근 완전 차단",
      "id": "db_sg",
      "inbound": [
        {
          "from": "app_sg (앱 서버에서만 접근 허용)",
          "port": "5432",
        },
      ],
      "name": "Database Security Group",
      "outbound": [],
    },
    {
      "color": "#7c3aed",
      "desc": "Redis는 앱에서만 접근. 직접 노출 금지",
      "id": "cache_sg",
      "inbound": [
        {
          "from": "app_sg (앱 서버에서만 허용)",
          "port": "6379",
        },
      ],
      "name": "ElastiCache Security Group",
      "outbound": [],
    },
    {
      "color": "#374151",
      "desc": "관리자 접근 전용. 사무실 IP만 허용",
      "id": "bastion_sg",
      "inbound": [
        {
          "from": "사무실 고정 IP/32 (반드시 특정 IP로 제한) - SSH/SSM 관리자 접근",
          "port": "22",
        },
      ],
      "name": "Bastion / VPN Endpoint Security Group",
      "outbound": [
        {
          "port": "22",
          "to": "app_sg (앱 서버 SSH 필요시)",
        },
        {
          "port": "5432",
          "to": "db_sg (DB 직접 쿼리 비상시)",
        },
      ],
    },
  ],
  "iac": "terraform",
}
`;
