          "from": "Office static IP/32 (must restrict to specific IP) - SSH/SSM admin access",
          "port": "22",
        },
      ],
      "name": "Bastion / VPN Endpoint Security Group",
      "outbound": [
        {
          "port": "22",
          "to": "app_sg (app server SSH when needed)",
        },
      ],
    },
  ],
  "iac": "terraform",
}
