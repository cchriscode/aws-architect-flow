          "port": "3000",
        },
      ],
      "name": "App Security Group",
      "outbound": [
        {
          "port": "5432",
          "to": "db_sg (PostgreSQL/Aurora PG)",
        },
        {
          "port": "6379",
          "to": "cache_sg (ElastiCache Redis)",
        },
        {
          "port": "443",
          "to": "443 (VPC Endpoint - Secrets Manager, ECR, CloudWatch)",
        },
      ],
    },
    {
      "color": "#dc2626",
      "desc": "DB는 앱/Lambda에서만 접근. 인터넷 접근 완전 차단",
      "id": "db_sg",
      "inbound": [
        {
          "from": "app_sg (앱 서버에서만 접근 허용)",
          "port": "5432",
        },
      ],
      "name": "Database Security Group",
      "outbound": [],
    },
    {
      "color": "#7c3aed",
      "desc": "Redis는 앱에서만 접근. 직접 노출 금지",
      "id": "cache_sg",
      "inbound": [
        {
          "from": "app_sg (앱 서버에서만 허용)",
          "port": "6379",
        },
      ],
      "name": "ElastiCache Security Group",
      "outbound": [],
    },
    {
      "color": "#374151",
      "desc": "관리자 접근 전용. 사무실 IP만 허용",
      "id": "bastion_sg",
      "inbound": [
        {
          "from": "사무실 고정 IP/32 (반드시 특정 IP로 제한) - SSH/SSM 관리자 접근",
          "port": "22",
        },
      ],
      "name": "Bastion / VPN Endpoint Security Group",
      "outbound": [
        {
          "port": "22",
          "to": "app_sg (앱 서버 SSH 필요시)",
        },
        {
          "port": "5432",
          "to": "db_sg (DB 직접 쿼리 비상시)",
        },
      ],
    },
  ],
  "iac": "terraform",
}
`;

exports[`generateSecurityGroups snapshots > eks_full (en) 1`] = `
{
  "code": "# Terraform -- Full Security Group chain

# CloudFront Managed Prefix List lookup
data "aws_ec2_managed_prefix_list" "cloudfront" {
  name = "com.amazonaws.global.cloudfront.origin-facing"
}

# ── ALB Security Group
resource "aws_security_group" "alb" {
  name_prefix = "alb-"
  vpc_id      = module.vpc.vpc_id
  description = "ALB Security Group"

  ingress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    # CloudFront Managed Prefix List (ID varies by region, verify with describe-managed-prefix-lists)
    prefix_list_ids = [data.aws_ec2_managed_prefix_list.cloudfront.id]
    description = "HTTPS from CloudFront"
  }
  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    # CloudFront Managed Prefix List (ID varies by region, verify with describe-managed-prefix-lists)
    prefix_list_ids = [data.aws_ec2_managed_prefix_list.cloudfront.id]
    description = "HTTP (redirect to HTTPS)"
  }
  egress {
    from_port       = 8080
    to_port         = 9090
    protocol        = "tcp"
    security_groups = [aws_security_group.app.id]
    description     = "ALB to App"
  }
}

# ── Application Security Group
resource "aws_security_group" "app" {
  name_prefix = "app-"
  vpc_id      = module.vpc.vpc_id
  description = "Application Security Group"

  ingress {
    from_port       = 8080
    to_port         = 8080
    protocol        = "tcp"
    security_groups = [aws_security_group.alb.id]
    description     = "ALB to App"
  }

  egress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]  # Via VPC Endpoint (Secrets Manager, ECR, CloudWatch)
    description = "AWS services via VPC Endpoint"
  }
  egress {
    from_port       = 5432
    to_port         = 5432
    protocol        = "tcp"
    security_groups = [aws_security_group.db.id]
    description     = "Application to DB"
  }
  egress {
    from_port       = 6379
    to_port         = 6379
    protocol        = "tcp"
    security_groups = [aws_security_group.cache.id]
    description     = "Application to Redis"
  }
}

# ── DB Security Group
resource "aws_security_group" "db" {
  name_prefix = "db-"
  vpc_id      = module.vpc.vpc_id
  description = "Database SG -- no internet, app/lambda only"

  ingress {
    from_port       = 5432
    to_port         = 5432
    protocol        = "tcp"
    security_groups = [aws_security_group.app.id]
    description     = "From app only"
  }
  # No outbound -- DB only responds (stateful, no explicit allow needed)
}

# ── Cache Security Group
resource "aws_security_group" "cache" {
  name_prefix = "cache-"
  vpc_id      = module.vpc.vpc_id
  description = "ElastiCache SG -- app only"

  ingress {
    from_port       = 6379
    to_port         = 6379
    protocol        = "tcp"
    security_groups = [aws_security_group.app.id]
    description     = "Redis from app only"
  }
}
",
  "groups": [
    {
      "color": "#2563eb",
      "desc": "Internet -> ALB inbound. CloudFront IP or 0.0.0.0/0",
      "id": "alb_sg",
      "inbound": [
        {
          "from": "CloudFront Managed Prefix List (com.amazonaws.global.cloudfront.origin-facing) - HTTPS traffic",
          "port": "443",
        },
        {
          "from": "CloudFront Managed Prefix List - HTTP (redirect to 443)",
          "port": "80",
        },
      ],
      "name": "ALB Security Group",
      "outbound": [
        {
          "port": "8080-9090",
          "to": "eks_node_sg (forward to app servers)",
        },
      ],
    },
    {
      "color": "#059669",
      "desc": "ALB -> app server. App -> DB/cache outbound",
      "id": "app_sg",
      "inbound": [
        {
          "from": "alb_sg (ALB to app)",
          "port": "1025-65535",
        },
        {
          "from": "eks_control_plane_sg (EKS Control Plane -> API webhook/admission (443))",
          "port": "443",
        },
        {
          "from": "eks_control_plane_sg (EKS Control Plane -> node metrics)",
          "port": "10250",
        },
      ],
      "name": "EKS Node Security Group",
      "outbound": [
        {
          "port": "5432",
          "to": "db_sg (PostgreSQL/Aurora PG)",
        },
        {
          "port": "6379",
          "to": "cache_sg (ElastiCache Redis)",
        },
        {
          "port": "443",
          "to": "search_sg (OpenSearch HTTPS)",
        },
        {
          "port": "443",
          "to": "443 (VPC Endpoints - Secrets Manager, ECR, CloudWatch)",
        },
        {
          "port": "2049",
          "to": "efs_sg (EFS NFS)",
        },
      ],
    },
    {
      "color": "#dc2626",
      "desc": "DB accessible from app/Lambda only. Internet access fully blocked",
      "id": "db_sg",
      "inbound": [
        {
          "from": "app_sg (allow access from app servers only)",
          "port": "5432",
        },
        {
          "from": "bastion_sg (additional access from bastion admin only)",
          "port": "5432",
        },
      ],
      "name": "Database Security Group",
      "outbound": [],
    },
    {
      "color": "#7c3aed",
      "desc": "Redis accessible from app only. Never expose directly",
      "id": "cache_sg",
      "inbound": [
        {
          "from": "app_sg (allow from app servers only)",
          "port": "6379",
        },
      ],
      "name": "ElastiCache Security Group",
      "outbound": [],
    },
    {
      "color": "#0891b2",
      "desc": "Search engine. HTTPS access from app only",
      "id": "search_sg",
      "inbound": [
        {
          "from": "app_sg (HTTPS from app only)",
          "port": "443",
        },
        {
          "from": "bastion_sg (OpenSearch Dashboard management)",
          "port": "443",
        },
      ],
      "name": "OpenSearch Security Group",
      "outbound": [],
    },
    {
      "color": "#16a34a",
      "desc": "EFS mount targets. NFS access from app only",
      "id": "efs_sg",
      "inbound": [
        {
          "from": "app_sg (NFS mount)",
          "port": "2049",
        },
      ],
      "name": "EFS Security Group",
      "outbound": [],
    },
    {
      "color": "#374151",
      "desc": "Admin access only. Allow office IP only",
      "id": "bastion_sg",
      "inbound": [
        {
          "from": "Office static IP/32 (must restrict to specific IP) - SSH/SSM admin access",
          "port": "22",
        },
      ],
      "name": "Bastion / VPN Endpoint Security Group",
      "outbound": [
        {
          "port": "22",
          "to": "app_sg (app server SSH when needed)",
        },
        {
          "port": "5432",
          "to": "db_sg (DB direct query for emergencies)",
        },
      ],
    },
    {
      "color": "#1d4ed8",
      "desc": "EKS managed SG. Do not modify directly",
      "id": "eks_control_plane_sg",
      "inbound": [
        {
          "from": "app_sg (node group) - kubectl API access",
          "port": "443",
        },
      ],
      "name": "EKS Control Plane Security Group",
      "outbound": [
        {
          "port": "1025-65535",
          "to": "app_sg (node group) - kubelet + pods (10250+)",
        },
        {
          "port": "443",
          "to": "app_sg (node group) - API server HTTPS",
        },
      ],
    },
  ],
  "iac": "terraform",
}
`;

