exports[`generateSecurityGroups snapshots > ecommerce_mvp (en) 1`] = `
{
  "code": "# Terraform -- Full Security Group chain

# CloudFront Managed Prefix List lookup
data "aws_ec2_managed_prefix_list" "cloudfront" {
  name = "com.amazonaws.global.cloudfront.origin-facing"
}

# ── ALB Security Group
resource "aws_security_group" "alb" {
  name_prefix = "alb-"
  vpc_id      = module.vpc.vpc_id
  description = "ALB Security Group"

  ingress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    # CloudFront Managed Prefix List (ID varies by region, verify with describe-managed-prefix-lists)
    prefix_list_ids = [data.aws_ec2_managed_prefix_list.cloudfront.id]
    description = "HTTPS from CloudFront"
  }
  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    # CloudFront Managed Prefix List (ID varies by region, verify with describe-managed-prefix-lists)
    prefix_list_ids = [data.aws_ec2_managed_prefix_list.cloudfront.id]
    description = "HTTP (redirect to HTTPS)"
  }
  egress {
    from_port       = 3000
    to_port         = 3000
    protocol        = "tcp"
    security_groups = [aws_security_group.app.id]
    description     = "ALB to App"
  }
}

# ── Application Security Group
resource "aws_security_group" "app" {
  name_prefix = "app-"
  vpc_id      = module.vpc.vpc_id
  description = "Application Security Group"

  ingress {
    from_port       = 3000
    to_port         = 3000
    protocol        = "tcp"
    security_groups = [aws_security_group.alb.id]
    description     = "ALB to App"
  }

  egress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]  # Via VPC Endpoint (Secrets Manager, ECR, CloudWatch)
    description = "AWS services via VPC Endpoint"
  }
  egress {
    from_port       = 5432
    to_port         = 5432
    protocol        = "tcp"
    security_groups = [aws_security_group.db.id]
    description     = "Application to DB"
  }
  egress {
    from_port       = 6379
    to_port         = 6379
    protocol        = "tcp"
    security_groups = [aws_security_group.cache.id]
    description     = "Application to Redis"
  }
}

# ── DB Security Group
resource "aws_security_group" "db" {
  name_prefix = "db-"
  vpc_id      = module.vpc.vpc_id
  description = "Database SG -- no internet, app/lambda only"

  ingress {
    from_port       = 5432
    to_port         = 5432
    protocol        = "tcp"
    security_groups = [aws_security_group.app.id]
    description     = "From app only"
  }
  # No outbound -- DB only responds (stateful, no explicit allow needed)
}

# ── Cache Security Group
resource "aws_security_group" "cache" {
  name_prefix = "cache-"
  vpc_id      = module.vpc.vpc_id
  description = "ElastiCache SG -- app only"

  ingress {
    from_port       = 6379
    to_port         = 6379
    protocol        = "tcp"
    security_groups = [aws_security_group.app.id]
    description     = "Redis from app only"
  }
}
",
  "groups": [
    {
      "color": "#2563eb",
      "desc": "Internet -> ALB inbound. CloudFront IP or 0.0.0.0/0",
      "id": "alb_sg",
      "inbound": [
        {
          "from": "CloudFront Managed Prefix List (com.amazonaws.global.cloudfront.origin-facing) - HTTPS traffic",
          "port": "443",
        },
        {
          "from": "CloudFront Managed Prefix List - HTTP (redirect to 443)",
          "port": "80",
        },
      ],
      "name": "ALB Security Group",
      "outbound": [
        {
          "port": "3000",
          "to": "app_sg (forward to app servers)",
        },
      ],
    },
    {
      "color": "#059669",
      "desc": "ALB -> app server. App -> DB/cache outbound",
      "id": "app_sg",
      "inbound": [
        {
          "from": "alb_sg (ALB to app)",
          "port": "3000",
        },
      ],
      "name": "App Security Group",
      "outbound": [
        {
          "port": "5432",
          "to": "db_sg (PostgreSQL/Aurora PG)",
        },
        {
          "port": "6379",
          "to": "cache_sg (ElastiCache Redis)",
        },
        {
          "port": "443",
          "to": "443 (VPC Endpoints - Secrets Manager, ECR, CloudWatch)",
        },
      ],
    },
    {
      "color": "#dc2626",
      "desc": "DB accessible from app/Lambda only. Internet access fully blocked",
      "id": "db_sg",
      "inbound": [
        {
          "from": "app_sg (allow access from app servers only)",
          "port": "5432",
        },
      ],
      "name": "Database Security Group",
      "outbound": [],
    },
    {
      "color": "#7c3aed",
      "desc": "Redis accessible from app only. Never expose directly",
      "id": "cache_sg",
      "inbound": [
        {
          "from": "app_sg (allow from app servers only)",
          "port": "6379",
        },
      ],
      "name": "ElastiCache Security Group",
      "outbound": [],
    },
    {
      "color": "#374151",
      "desc": "Admin access only. Allow office IP only",
      "id": "bastion_sg",
      "inbound": [
        {
          "from": "Office static IP/32 (must restrict to specific IP) - SSH/SSM admin access",
          "port": "22",
        },
      ],
      "name": "Bastion / VPN Endpoint Security Group",
      "outbound": [
        {
          "port": "22",
          "to": "app_sg (app server SSH when needed)",
        },
        {
          "port": "5432",
          "to": "db_sg (DB direct query for emergencies)",
        },
      ],
    },
  ],
  "iac": "terraform",
}
`;

