exports[`generateSecurityGroups snapshots > serverless (en) 1`] = `
{
  "code": "# Terraform -- Full Security Group chain

# ── ALB Security Group
resource "aws_security_group" "alb" {
  name_prefix = "alb-"
  vpc_id      = module.vpc.vpc_id
  description = "ALB Security Group"

  ingress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "HTTPS from internet"
  }
  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "HTTP (redirect to HTTPS)"
  }
  egress {
    from_port       = 3000
    to_port         = 3000
    protocol        = "tcp"
    security_groups = [aws_security_group.lambda.id]
    description     = "ALB to App"
  }
}

# ── Lambda Security Group
resource "aws_security_group" "lambda" {
  name_prefix = "lambda-"
  vpc_id      = module.vpc.vpc_id
  description = "Lambda Security Group"

  # Lambda: no inbound rules (Lambda only communicates outbound)

  egress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]  # Via VPC Endpoint (Secrets Manager, ECR, CloudWatch)
    description = "AWS services via VPC Endpoint"
  }
}
",
  "groups": [
    {
      "color": "#2563eb",
      "desc": "Internet -> ALB inbound. CloudFront IP or 0.0.0.0/0",
      "id": "alb_sg",
      "inbound": [
        {
          "from": "0.0.0.0/0 (HTTPS traffic)",
          "port": "443",
        },
        {
          "from": "0.0.0.0/0 (HTTP -> 443 redirect)",
          "port": "80",
        },
      ],
      "name": "ALB Security Group",
      "outbound": [
        {
          "port": "3000",
          "to": "app_sg (forward to app servers)",
        },
      ],
    },
    {
      "color": "#f59e0b",
      "desc": "Required when Lambda is placed in VPC. No inbound (Lambda has no external listener)",
      "id": "lambda_sg",
      "inbound": [],
      "name": "Lambda Security Group",
      "outbound": [
        {
          "port": "443",
          "to": "0.0.0.0/0 VPC Endpoint (Secrets Manager, DynamoDB, S3)",
        },
      ],
    },
  ],
  "iac": "terraform",
}
`;

