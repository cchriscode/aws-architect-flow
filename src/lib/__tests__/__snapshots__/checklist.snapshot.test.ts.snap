          "id": 76,
          "link": "",
          "text": "Create CloudWatch dashboard",
        },
        {
          "critical": true,
          "detail": "5xx rate > 1%, response time p99 > 2s, HealthyHostCount < 2",
          "id": 77,
          "link": "",
          "text": "Set up ALB alarms",
        },
        {
          "critical": false,
          "detail": "CPUUtilization > 80%, MemoryUtilization > 85%, Running Task < min",
          "id": 78,
          "link": "",
          "text": "Set up ECS alarms",
        },
        {
          "critical": true,
          "detail": "FreeStorage < 10GB, CPUUtilization > 80%, DatabaseConnections > 200, ReplicationLag > 1s",
          "id": 79,
          "link": "",
          "text": "Set up RDS/Aurora alarms",
        },
        {
          "critical": false,
          "detail": "EngineCPUUtilization > 80%, Evictions > 1000/min, CurrConnections > 500",
          "id": 80,
          "link": "",
          "text": "Set up ElastiCache alarms",
        },
        {
          "critical": true,
          "detail": "Create Canary per major API endpoint. 5-min health check intervals. On failure: CloudWatch Alarm -> SNS immediate alert",
          "id": 81,
          "link": "",
          "text": "Set up CloudWatch Synthetics Canary",
        },
        {
          "critical": false,
          "detail": "Email + Slack (ChatBot) subscription. Configure severity-based escalation",
          "id": 82,
          "link": "",
          "text": "Create SNS alert topic (on-call)",
        },
        {
          "critical": false,
          "detail": "Trace entire path: ALB -> App -> DB. Analyze slow request causes",
          "id": 83,
          "link": "",
          "text": "Enable X-Ray distributed tracing",
        },
      ],
      "label": "Monitoring & Operations Setup",
      "phase": "Phase 9",
    },
    {
      "icon": "🎯",
      "items": [
        {
          "critical": false,
          "detail": "Test at 1.5x target RPS. 5-minute test. Identify bottlenecks",
          "id": 84,
          "link": "",
          "text": "Run load test (k6 or Artillery)",
        },
        {
          "critical": false,
          "detail": "Trigger CPU threshold breach then measure scale-out time. Verify scale-in works correctly",
          "id": 85,
          "link": "",
          "text": "Verify Auto Scaling behavior",
        },
        {
          "critical": true,
          "detail": "Force Aurora failover. Measure app reconnection time. Verify Read Replica promotion",
          "id": 86,
          "link": "",
          "text": "Test DB failover",
        },
        {
          "critical": false,
          "detail": "Response procedures per failure scenario. Contact list. Escalation framework. Quarterly drills",
          "id": 87,
          "link": "",
          "text": "Document DR recovery procedures",
        },
        {
          "critical": false,
          "detail": "Amazon Inspector (EC2/Lambda/ECR images). Fix HIGH severity and above immediately",
          "id": 88,
          "link": "",
          "text": "Run security vulnerability scan",
        },
        {
          "critical": false,
          "detail": "Test immediate rollback after Blue/Green switch",
          "id": 89,
          "link": "",
          "text": "Verify rollback procedures",
        },
        {
          "critical": false,
          "detail": "Grant operations team CloudWatch access. Register alarm recipients. Set on-call schedule",
          "id": 90,
          "link": "",
          "text": "Share monitoring dashboard with team",
        },
        {
          "critical": false,
          "detail": "Lower DNS TTL (5 min) -> switch traffic -> monitor 10 min -> restore TTL",
          "id": 91,
          "link": "",
          "text": "Final launch checklist review",
        },
      ],
      "label": "Performance Testing & Launch Preparation",
      "phase": "Phase 10",
    },
  ],
  "totalItems": 91,
}
`;

