      "services": [
        {
          "cost": "Free",
          "detail": "Prod / Stage / Dev accounts",
          "name": "Environment-based account separation",
          "opt": "Automate account management with Control Tower",
          "reason": "Full isolation between environments, enhanced security",
        },
      ],
    },
    {
      "bg": "#eef2ff",
      "color": "#4f46e5",
      "icon": "🌐",
      "id": "network",
      "insights": [
        "DB in isolated subnet has no internet. Access via SSM Session Manager",
        "NAT GW 2 NAT GWs for outbound protection during AZ failure",
        "Chain Security Groups by referencing SG IDs instead of IPs",
      ],
      "label": "Network Design",
      "services": [
        {
          "cost": "Free",
          "detail": "ap-northeast-2, /16 CIDR, 2 AZ",
          "name": "VPC",
          "opt": "Consider future expansion when designing CIDR",
          "reason": "Resource isolation boundary",
        },
        {
          "cost": "Free",
          "detail": "Public ×2 + Private ×2 + Isolated ×2 (6 total)",
          "name": "Subnet Configuration",
          "opt": "Recommended /24 CIDR per AZ subnet",
          "reason": "Full DB isolation, minimized attack surface",
        },
        {
          "cost": "~$43/mo each + $0.045/GB",
          "detail": "Private subnet outbound",
          "name": "NAT GW ×2 (1 per AZ, HA)",
          "opt": "Reduce NAT costs by using VPC Endpoints",
          "reason": "Access AWS services like ECR, Secrets",
        },
        {
          "cost": "Gateway EP free, Interface EP $7/mo each",
          "detail": "S3, ECR, SecretsManager, CloudWatch, SSM",
          "name": "VPC Endpoint",
          "opt": "Prefer free Gateway Endpoints for S3/DynamoDB",
          "reason": "Bypass NAT GW, enhanced security",
        },
      ],
    },
    {
      "bg": "#ecfeff",
      "color": "#0891b2",
      "icon": "🚀",
      "id": "edge",
      "insights": [
        "Place ALB in public subnets, app servers in private subnets",
        "Enable CloudFront Origin Shield for enhanced origin protection",
        "Route 53 health check interval at 10s detects failures within 30s max",
      ],
      "label": "Edge/CDN",
      "services": [
        {
          "cost": "$0.50/hosted zone/mo",
          "detail": "Health check + failover routing",
          "name": "Route 53",
          "opt": "Integrate internal DNS with health checks + Route53 Resolver",
          "reason": "DNS management + domain routing",
        },
        {
          "cost": "Public certificates free (when linked to ALB/CloudFront)",
          "detail": "Auto-issue and renew TLS certificates for ALB/CloudFront",
          "name": "AWS Certificate Manager (ACM)",
          "opt": "Only certificates issued in us-east-1 can be used with CloudFront. Separate issuance required per region",
          "reason": "In-transit encryption (TLS 1.2+) required. Auto-renewal eliminates operational risk",
        },
        {
          "cost": "$0.120/GB (Korea, first 10TB)",
          "detail": "Static files + dynamic cache",
          "name": "CloudFront",
          "opt": "Block direct S3 access with OAC (Origin Access Control). OAI is deprecated -- use OAC",
          "reason": "Reduce origin traffic, global distribution",
        },
        {
          "cost": "~$20/mo+",
          "detail": "In front of CloudFront/ALB",
          "name": "WAF",
          "opt": "Reduce custom rule costs with managed rules",
          "reason": "OWASP",
        },
        {
          "cost": "CloudFront Functions $0.1/1M req, Lambda@Edge $0.6/1M",
