generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?      @map("email_verified")
  image         String?
  accounts      Account[]
  history       HistoryEntry[] @relation("UserHistory")
  posts         BlogPost[]

  @@map("users")
}

model BlogCategory {
  id        String     @id @default(uuid())
  name      String     @unique
  slug      String     @unique
  sortOrder Int        @default(0) @map("sort_order")
  posts     BlogPost[]
  createdAt DateTime   @default(now()) @map("created_at")

  @@map("blog_categories")
}

model BlogPost {
  id           String        @id @default(uuid())
  slug         String
  title        String
  content      String        @db.Text
  excerpt      String        @default("")
  thumbnailUrl String?       @map("thumbnail_url")
  tags         String[]
  categoryId   String?       @map("category_id")
  category     BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  series       String?
  seriesOrder  Int?          @map("series_order")
  published    Boolean       @default(false)
  publishedAt  DateTime?     @map("published_at")
  readingTime  Int           @default(1) @map("reading_time")
  views        Int           @default(0)
  authorId     String        @map("author_id")
  author       User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@unique([categoryId, slug])
  @@index([published, publishedAt(sort: Desc)])
  @@index([slug])
  @@index([categoryId])
  @@map("blog_posts")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model HistoryEntry {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  name            String
  savedAt         DateTime @default(now()) @map("saved_at")
  state           Json
  completedPhases Json     @map("completed_phases")
  headline        String
  monthlyCost     Float    @map("monthly_cost")
  wafrScore       Float    @map("wafr_score")
  archPattern     String   @map("arch_pattern")
  workloadTypes   Json     @map("workload_types")
  user            User     @relation("UserHistory", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("history_entries")
}

model Share {
  id              String   @id @default(uuid())
  shortId         String   @unique @map("short_id")
  state           Json
  completedPhases Json     @map("completed_phases")
  headline        String
  monthlyCost     Float    @map("monthly_cost")
  wafrScore       Float    @map("wafr_score")
  serviceCount    Int      @map("service_count")
  createdAt       DateTime @default(now()) @map("created_at")
  expiresAt       DateTime @map("expires_at")

  @@map("shares")
}
